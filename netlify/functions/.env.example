# Netlify Environment Variables — set in Netlify UI, not committed
# Site settings → Environment variables

# Anthropic (existing)
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs voice for Carlos
# API key: elevenlabs.io → Profile → API Keys
# Voice ID: elevenlabs.io → Voice Library → click voice → copy ID from URL or "Use" dialog
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=F2uBj6ZNNG9Ub2poNhvS

# Carlos chat — add these in Netlify → Site settings → Environment variables
RAG_BASE_URL=https://rag-command-center.onrender.com
WINDMILL_BASE_URL=https://windmill-server-production-1d21.up.railway.app
WINDMILL_TOKEN=
WINDMILL_WORKSPACE=thryve

# Carlos ElevenAgent — generated by running: node setup/create-carlos-agent.js
CARLOS_AGENT_ID=
# Optional: set after generating HMAC secret for post-call webhook verification
ELEVENLABS_WEBHOOK_SECRET=

# Supabase (existing project: wfswbuqhpzdtdnrklgqu)
SUPABASE_URL=https://wfswbuqhpzdtdnrklgqu.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Whoop Developer API — get from developer.whoop.com
# 1. Sign in with your Whoop account
# 2. Create app named "Baseline"
# 3. Set redirect URI to: https://<your-netlify-subdomain>.netlify.app/api/whoop-callback
# 4. Copy Client ID and Client Secret below
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=https://<your-netlify-subdomain>.netlify.app/api/whoop-callback
